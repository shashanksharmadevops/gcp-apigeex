<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<AccessControl async="false" continuenError="false" enabled="true" name="AC-Allow-All-Deny-Few" >
<DisplayName>AC-Allow-All-Deny-Few</DisplayName>
<Properties/>
<IgnoreTrueClientIPHeader>true</IgnoreTrueClientIPHeader>
<IPRules noRuleMatchAction="ALLOW">
